{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Discord Bot",
			"type": "shell",
			"command": "npm run start",
			"args": [],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Start Frontend Dashboard",
			"type": "shell",
			"command": "npm",
			"args": [
				"--prefix",
				"frontend",
				"run",
				"dev"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Start Full Platform (Bot + Frontend)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"platform:up"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "Monitor: Stack Health",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"monitor:stack"
			],
			"problemMatcher": [],
			"group": {
				"kind": "test",
				"isDefault": false
			}
		},
		{
			"label": "Stryker: Run in Sandbox (Node.js Isolated)",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/stryker-sandbox.js"
			],
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": false
			},
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "Stryker: Run in Sandbox (Bash Shell Isolated)",
			"type": "shell",
			"command": "bash",
			"args": [
				"scripts/stryker-sandbox.sh"
			],
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "dedicated",
				"showReuseMessage": false,
				"clear": true
			}
		},
		{
			"label": "Stryker: Cleanup Sandboxes",
			"type": "shell",
			"command": "rm",
			"args": [
				"-rf",
				"${workspaceFolder}/.stryker-tmp",
				"${workspaceFolder}/.stryker-sandbox",
				"${workspaceFolder}/.stryker-sandbox-tmp"
			],
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "shared"
			}
		},
		{
			"label": "Stryker: View Latest Report",
			"type": "shell",
			"command": "ls",
			"args": [
				"-lah",
				"${workspaceFolder}/reports/mutation-sandbox"
			],
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			}
		},
		{
			"label": "Jest: Test Sandbox Isolation",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:isolate"
			],
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": [
				"$jest"
			]
		},
		{
			"label": "Jest: Test with Cache Clear",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"test:clean"
			],
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": [
				"$jest"
			]
		},
		{
			"label": "Build: Full Clean Build",
			"type": "shell",
			"command": "sh",
			"args": [
				"-c",
				"rm -rf dist node_modules/.cache && npm run build"
			],
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": [
				"$tsc"
			]
		}
	]
}