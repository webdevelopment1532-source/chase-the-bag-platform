import { playBlackjack, playPlinko, playMines } from '../src/games';

describe('Rapid Mutation Hunt', () => {
  // Core output tests
  test('BJ returns string', () => {
    expect(typeof playBlackjack(() => 0.5)).toBe('string');
  });
  
  test('PL returns string', () => {
    expect(typeof playPlinko(() => 0.5)).toBe('string');
  });
  
  test('MN returns string', () => {
    expect(typeof playMines(() => 0.5)).toBe('string');
  });

  // String mutation detection
  test('BJ has colon-space format', () => {
    const r = playBlackjack(() => 0.5);
    expect(r).toContain('Player: ');
    expect(r).toContain('Dealer: ');
  });

  test('PL has arrow separators', () => {
    const r = playPlinko(() => 0.5);
    expect(r).toContain(' -> ');
  });

  test('MN has tile prefix', () => {
    const r = playMines(() => 0.5);
    expect(r).toContain('Pick: tile');
  });

  // Array and loop mutations
  test('BJ player hand has cards', () => {
    const r = playBlackjack(() => 0.5);
    expect(r).toMatch(/Player: [A2-9JQK]/);
  });

  test('PL slot value present', () => {
    const r = playPlinko(() => 0.5);
    expect(r).toMatch(/Landing slot: \d+/);
  });

  test('MN tile value 1-9', () => {
    const r = playMines(() => 0.5);
    expect(r).toMatch(/tile [0-9]/);
  });

  // Verdict/outcome mutations
  test('BJ verdict exists', () => {
    const r = playBlackjack(() => 0.5);
    expect(r).toMatch(/Result: \*\*[^*]+\*\*/);
  });

  test('PL payout exists', () => {
    const r = playPlinko(() => 0.5);
    expect(r).toMatch(/Payout: \*\*[\d.]+x\*\*/);
  });

  test('MN result exists', () => {
    const r = playMines(() => 0.5);
    expect(r).toMatch(/Result: \*\*(Safe|Boom)\*\*/);
  });

  // Path logic mutation
  test('BJ total calculation', () => {
    const r = playBlackjack(() => 0.1);
    expect(r).toMatch(/\(\d+\)/);
  });

  test('PL path has 6 moves', () => {
    const r = playPlinko(() => 0.5);
    const arrows = (r.match(/ -> /g) || []).length;
    expect(arrows).toBe(5); // 6 moves = 5 arrows
  });

  test('MN board grid', () => {
    const r = playMines(() => 0.5);
    const boardElements = (r.match(/[⬜💎💥]/g) || []).length;
    expect(boardElements).toBe(9);
  });

  // Safe vs Boom conditional
  test('MN safe path', () => {
    let idx = 0;
    const vals = [0.5, 0.99, 0.99, 0.99];
    const r = playMines(() => vals[idx++] ?? 0.5);
    expect(r).toContain('Safe');
  });

  test('MN boom path has 3 mines shown', () => {
    let idx = 0;
    const vals = [0.5, 0.05, 0.05, 0.05];
    const r = playMines(() => vals[idx++] ?? 0.5);
    expect(r).toContain('Boom');
  });
});
