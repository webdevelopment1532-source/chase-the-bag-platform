{
  "name": "discord-game-server",
  "version": "1.0.0",
  "description": "A Discord bot for game server competitions and rewards.",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "dev": "ts-node-dev src/index.ts",
    "setup:hooks": "git config core.hooksPath .githooks && chmod +x .githooks/pre-push",
    "db:init": "node scripts/init-db.js",
    "db:check": "node scripts/init-db.js --check",
    "test": "jest"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "discord.js": "^14.13.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "mysql2": "^3.20.0",
    "node-fetch": "^3.3.2",
    "ts-node-dev": "^2.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
