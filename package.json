{
  "name": "discord-game-server",
  "version": "1.0.0",
  "description": "A Discord bot for game server competitions and rewards.",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "dev": "ts-node-dev src/index.ts",
    "dev:frontend": "npm --prefix frontend run dev",
    "monitor:stack": "node scripts/monitor-stack.js",
    "platform:up": "npm run build && sh -c 'node dist/index.js & npm --prefix frontend run dev'",
    "setup:hooks": "git config core.hooksPath .githooks && chmod +x .githooks/pre-push",
    "db:init": "node scripts/init-db.js",
    "db:check": "node scripts/init-db.js --check",
    "test": "jest",
    "test:clean": "jest --clearCache && jest",
    "test:isolate": "jest --clearCache && jest --runInBand",
    "stryker": "npx stryker run",
    "stryker:sandbox": "node scripts/stryker-sandbox.js",
    "stryker:sandbox:bash": "bash scripts/stryker-sandbox.sh",
    "stryker:sandbox:cleanup": "rm -rf .stryker-tmp .stryker-sandbox .stryker-sandbox-tmp && npx jest --clearCache",
    "scraper": "node scripts/scraper-cli.js",
    "scraper:watch": "node scripts/scraper-cli.js --watch",
    "scraper:once": "node scripts/scraper-cli.js",
    "rag:index": "npm run build && node dist/rag-cli.js --index",
    "rag:query": "npm run build && node dist/rag-cli.js"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "discord.js": "^14.13.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "mysql2": "^3.20.0",
    "node-fetch": "^3.3.2",
    "ts-node-dev": "^2.0.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.2"
  }
}
