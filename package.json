    "archiver": "^7.0.1",
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "discord-oauth2": "^2.12.1",
    "discord.js": "^14.26.2",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "fastify": "^5.8.4",
    "framer-motion": "^12.38.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
