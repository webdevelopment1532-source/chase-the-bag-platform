{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-js/master/packages/api/schema/stryker-schema.json",
  "testRunner": "jest",
  "coverageAnalysis": "off",
  "reporters": ["clear-text", "html", "progress"],
  "mutate": ["src/chart.ts", "src/crawler-service.ts", "src/export-data.ts", "src/db.ts", "src/events.ts"],
  "mutator": {
    "excludedMutations": [
      "BooleanLiteral",
      "StringLiteral",
      "ObjectLiteral",
      "ConditionalExpression",
      "BlockStatement",
      "LogicalOperator",
      "EqualityOperator",
      "ArrayDeclaration",
      "MethodExpression",
      "Regex",
      "ArithmeticOperator",
      "OptionalChaining",
      "ArrowFunction",
      "UnaryOperator",
      "AssignmentOperator"
    ]
  },
  "jest": {
    "projectType": "custom",
    "configFile": "jest.config.js"
  },
  "thresholds": {
    "high": 100,
    "low": 100,
    "break": 100
  }
}
