#!/usr/bin/env sh

# Block direct pushes to main. Use feature branches + PRs.
protected_branch="main"

while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    "refs/heads/$protected_branch")
      echo "Push blocked: direct pushes to '$protected_branch' are disabled locally."
      echo "Create a feature branch and open a pull request instead."
      exit 1
      ;;
  esac
done

if [ "$SKIP_COVERAGE_CHECK" = "1" ]; then
  echo "Skipping coverage check because SKIP_COVERAGE_CHECK=1"
  exit 0
fi

echo "Running coverage ratchet check before push..."
npm run coverage:strict
status=$?
if [ "$status" -ne 0 ]; then
  echo "Push blocked: strict 100% coverage check failed."
  echo "Run 'npm run test:coverage' and cover all uncovered code paths before pushing."
  exit "$status"
fi

exit 0
