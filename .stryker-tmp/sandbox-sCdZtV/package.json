{
  "name": "chase-the-bag-platform",
  "version": "1.0.0",
  "main": "dist/backend/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/backend/server.js",
    "bot": "node dist/bot/bot.js",
    "dev": "concurrently \"npm run start\" \"npm run bot\"",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linter configured'",
    "coverage": "jest --coverage",
    "mutation": "stryker run",
    "verify": "npm run typecheck && npm run build && npm run coverage && npm run mutation"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@types/joi": "^17.2.3",
    "axios": "^1.14.0",
    "discord.js": "^14.26.2",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.4",
    "joi": "^18.1.2",
    "mysql2": "^3.20.0",
    "uuid": "^9.0.1",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.39",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "concurrently": "^8.2.2",
    "fast-check": "^4.6.0",
    "jest": "^30.3.0",
    "jest-junit": "^16.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
