# Discord app credentials
DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_PUBLIC_KEY=your-discord-public-key
OWNER_DISCORD_USER_ID=your-discord-user-id

# MySQL/MariaDB config
DISCORD_GAME_DB_HOST=localhost
DISCORD_GAME_DB_PORT=3306
DISCORD_GAME_DB_USER=your_db_user
DISCORD_GAME_DB_PASS=your_db_password
DISCORD_GAME_DB_NAME=discord_game_server

# App config
STAKE_AFFILIATE_CODE=selfmade
GAME_CHANNEL_ID=your-game-channel-id
COIN_EXCHANGE_CHANNEL_ID=your-coin-exchange-channel-id
COIN_EXCHANGE_ADMIN_IDS=comma,separated,discord,user,ids
COMMAND_COOLDOWN_MS=1200
EXCHANGE_COMMAND_COOLDOWN_MS=1200
API_PORT=3001

# API security (required for dashboard/API access)
API_AUTH_TOKEN=replace_with_a_long_random_token
API_ADMIN_ID=dashboard-admin
